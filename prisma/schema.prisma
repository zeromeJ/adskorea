generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum InquiryStatus {
  PENDING
  COMPLETED
}

enum ResponseMethod {
  EMAIL
  PHONE
  TEXT
  BOTH
  ANY
}

model Inquiry {
  id                 String                 @id @default(cuid())
  companyName        String
  contactPerson      String
  email              String?
  phone              String?
  responseMethod     ResponseMethod         @default(ANY)
  inquiryType        String                 @default("일반 제품 문의")
  department         String?
  inquiryDetails     Json?
  country            String?
  industry           String?
  currentPalletType  String?
  productInterest    String?
  cargoType          String?
  loadPerPallet      String?
  estimatedQuantity  String?
  requiredPalletSize String?
  exportCountry      String?
  rackStorage        Boolean?
  automationUse      Boolean?
  forkliftUse        Boolean?
  handPalletTruckUse Boolean?
  message            String?                @db.VarChar(1500)
  status             InquiryStatus          @default(PENDING)
  adminMemo          String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  completionLogs     InquiryCompletionLog[]
  attachments        InquiryAttachment[]
}

model InquiryAttachment {
  id          String   @id @default(cuid())
  inquiryId   String
  fileName    String
  contentType String
  size        Int
  storagePath String   @unique
  createdAt   DateTime @default(now())
  inquiry     Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
}

model AdminUser {
  id             String                 @id @default(cuid())
  username       String                 @unique
  passwordHash   String
  displayName    String?
  isActive       Boolean                @default(true)
  isSuperAdmin   Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  devices        AdminDevice[]
  completionLogs InquiryCompletionLog[]
}

model InquiryCompletionLog {
  id               String     @id @default(cuid())
  inquiryId        String
  adminUserId      String?
  adminUsername    String
  adminDisplayName String?
  completedAt      DateTime   @default(now())
  inquiry          Inquiry    @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  adminUser        AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([completedAt])
  @@index([inquiryId])
  @@index([adminUserId])
}

model AdminDevice {
  id          String    @id @default(cuid())
  adminUserId String
  token       String    @unique
  platform    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
}
