DATABASE_URL="postgresql://ads_admin:ads_password@localhost:5432/ads_inquiry?schema=public"

RESEND_API_KEY="your_resend_api_key_here"

# CONTACT_RECEIVER_EMAIL:
# This is the backup email address that receives inquiry notifications.
# Current receiver: skduddkekffu@gmail.com
# Change this value later if the company wants to receive inquiries at another email.
CONTACT_RECEIVER_EMAIL="skduddkekffu@gmail.com"

# CONTACT_SENDER_EMAIL:
# For development, onboarding@resend.dev may be used depending on Resend restrictions.
# For production, use a verified domain email address.
CONTACT_SENDER_EMAIL="onboarding@resend.dev"

JWT_SECRET="replace_this_with_a_long_random_secret"

# Firebase Admin service account JSON serialized on one line.
# Keep this server-side only. Never expose it with a NEXT_PUBLIC_ prefix.
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"your-project-id"}'

# ADMIN_INITIAL_USERNAME and ADMIN_INITIAL_PASSWORD:
# Development default is admin / 1234.
# Change before production.
ADMIN_INITIAL_USERNAME="admin"
ADMIN_INITIAL_PASSWORD="1234"
